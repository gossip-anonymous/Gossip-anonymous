                      <div>
                        <p style={{ fontSize: 12, fontWeight: 700, color: C.accent }}>anonymous_user</p>
                        <div style={{ display: "flex", alignItems: "center", gap: 5 }}>
                          <Icon name="mail" size={11} color={C.adminAccent} />
                          <span style={{ fontSize: 12, color: C.adminAccent }}>{email}</span>
                          {admins.has(email) && <span className="admin-badge">admin</span>}
                        </div>
                      </div>
                    </div>
                    <div style={{ display: "flex", gap: 16, fontSize: 12, color: C.textMuted }}>
                      <span><strong style={{ color: C.text }}>{count}</strong> posts</span>
                      <span><strong style={{ color: C.text }}>{userLikes}</strong> likes</span>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {tab === "admins" && (
        <div className="fade-up">
          <div className="card" style={{ padding: "20px 22px", marginBottom: 16 }}>
            <p style={{ fontSize: 13, fontWeight: 700, color: C.text, marginBottom: 12 }}>Grant admin access</p>
            <div style={{ display: "flex", gap: 10 }}>
              <input type="email" placeholder="user@email.com" value={newAdmin} onChange={e => setNewAdmin(e.target.value)} onKeyDown={e => e.key === "Enter" && grantAdmin()} style={{ flex: 1 }} />
              <button className="btn-primary" onClick={grantAdmin} style={{ flexShrink: 0, background: C.adminAccent, padding: "10px 18px" }}>Grant</button>
            </div>
            {adminErr && <p style={{ color: C.red, fontSize: 12, marginTop: 8, fontWeight: 500 }}>{adminErr}</p>}
            {adminOk && <p style={{ color: C.green, fontSize: 12, marginTop: 8, fontWeight: 500 }}>✓ {adminOk}</p>}
          </div>

          <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
            {[...admins].map(email => (
              <div key={email} className="card" style={{ padding: "14px 20px", display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
                  <Icon name="crown" size={16} color={C.adminAccent} />
                  <div>
                    <span style={{ fontSize: 13, color: C.text, fontWeight: 600 }}>{email}</span>
                    {email === ADMIN_EMAIL && <span style={{ fontSize: 11, color: C.textMuted, display: "block" }}>owner — cannot be revoked</span>}
                  </div>
                </div>
                {email !== ADMIN_EMAIL && (
                  <button onClick={() => revokeAdmin(email)} style={{ background: C.redLight, color: C.red, border: `1px solid #fecaca`, borderRadius: 7, padding: "6px 12px", fontSize: 12, fontWeight: 600 }}>
                    revoke
                  </button>
                )}
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}

// ─── Root ─────────────────────────────────────────────────────────────────────
export default function Root() {
  const [screen, setScreen] = useState("landing");
  const [userEmail, setUserEmail] = useState(null);

  const handleAuth = (email) => { setUserEmail(email); setScreen("app"); };
  const handleSignout = () => { setUserEmail(null); setScreen("landing"); };

  return (
    <>
      <style>{css}</style>
      {screen === "landing" && <Landing onNav={setScreen} />}
      {(screen === "signup" || screen === "login") && <Auth mode={screen} onNav={setScreen} onAuth={handleAuth} />}
      {screen === "app" && <App userEmail={userEmail} onSignout={handleSignout} />}
    </>
  );
}
