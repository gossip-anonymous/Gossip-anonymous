// ─── Landing ──────────────────────────────────────────────────────────────────
function Landing({ onNav }) {
  const [wi, setWi] = useState(0);
  const [disp, setDisp] = useState("");
  const [typing, setTyping] = useState(true);
  const words = ["anonymous.", "hidden.", "the tea.", "unfiltered.", "free."];

  useState(() => {
    let t;
    const tick = () => {
      const w = words[wi];
      setDisp(d => {
        if (typing) {
          if (d.length < w.length) { t = setTimeout(tick, 85); return w.slice(0, d.length + 1); }
          else { t = setTimeout(() => { setTyping(false); tick(); }, 1600); return d; }
        } else {
          if (d.length > 0) { t = setTimeout(tick, 40); return d.slice(0, -1); }
          else { setWi(i => (i + 1) % words.length); setTyping(true); t = setTimeout(tick, 100); return d; }
        }
      });
    };
    t = setTimeout(tick, 400);
    return () => clearTimeout(t);
  }, []);

  return (
    <div style={{ minHeight: "100vh", display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", padding: 24, background: `linear-gradient(160deg, #f0eeff 0%, ${C.bg} 50%, #fff8f0 100%)` }}>
      <div style={{ maxWidth: 580, width: "100%", textAlign: "center" }} className="fade-up">
        <div style={{ display: "inline-flex", alignItems: "center", gap: 8, background: C.accentLight, border: `1px solid ${C.accentMid}`, borderRadius: 100, padding: "6px 16px", marginBottom: 40 }}>
          <div style={{ width: 6, height: 6, borderRadius: "50%", background: C.accent }} />
          <span style={{ fontSize: 12, fontWeight: 600, color: C.accent, letterSpacing: "0.1em", textTransform: "uppercase" }}>gossip-anonymous</span>
        </div>

        <h1 style={{ fontFamily: "'Playfair Display', serif", fontSize: "clamp(44px, 8vw, 72px)", fontWeight: 800, lineHeight: 1.1, letterSpacing: "-0.01em", marginBottom: 20, color: C.text }}>
          say anything.<br />
          <span style={{ color: C.accent }}>be {disp}<span className="cursor" /></span>
        </h1>

        <p style={{ color: C.textMuted, fontSize: 16, lineHeight: 1.7, marginBottom: 44, maxWidth: 420, margin: "0 auto 44px" }}>
          Spill it. Say it. Stay anonymous. Every voice is still <strong style={{ color: C.text }}>anonymous_user</strong> — no names, no receipts, just the real tea.
        </p>

        <div style={{ display: "flex", gap: 12, justifyContent: "center", flexWrap: "wrap" }}>
          <button className="btn-primary" onClick={() => onNav("signup")} style={{ padding: "13px 32px", fontSize: 14, fontWeight: 700 }}>
            join gossip-anonymous →
          </button>
          <button className="btn-ghost" onClick={() => onNav("login")}>sign in</button>
        </div>

        <div style={{ display: "flex", gap: 32, justifyContent: "center", marginTop: 56, color: C.textDim, fontSize: 12 }}>
          {["no profiles visible", "no names attached", "just the real tea"].map(t => (
            <span key={t} style={{ display: "flex", alignItems: "center", gap: 6 }}>
              <span style={{ color: C.accent, fontWeight: 700 }}>✓</span> {t}
            </span>
          ))}
        </div>
      </div>
    </div>
  );
}

// ─── Auth ─────────────────────────────────────────────────────────────────────
function Auth({ mode, onNav, onAuth }) {
  const isSig = mode === "signup";
  const [email, setEmail] = useState("");
  const [pw, setPw] = useState("");
  const [loading, setLoading] = useState(false);
  const [step, setStep] = useState("form");
  const [code, setCode] = useState("");
  const [err, setErr] = useState("");
  const [vCode] = useState(() => Math.floor(100000 + Math.random() * 900000).toString());

  const submit = () => {
    if (!email || !pw) { setErr("please fill in both fields."); return; }
    if (!/\S+@\S+\.\S+/.test(email)) { setErr("that doesn't look like a valid email."); return; }
    if (pw.length < 6) { setErr("password must be at least 6 characters."); return; }
    setErr(""); setLoading(true);
    setTimeout(() => { setLoading(false); if (isSig) setStep("verify"); else onAuth(email); }, 1000);
  };

  const verify = () => {
    if (code === vCode) onAuth(email);
    else setErr(`wrong code. (hint: ${vCode})`);
  };

  return (
    <div style={{ minHeight: "100vh", display: "flex", alignItems: "center", justifyContent: "center", padding: 24, background: `linear-gradient(160deg, #f0eeff 0%, ${C.bg} 60%)` }}>
      <div className="fade-up" style={{ maxWidth: 420, width: "100%" }}>
        <button onClick={() => onNav("landing")} style={{ background: "none", color: C.textMuted, fontSize: 13, marginBottom: 36, display: "flex", alignItems: "center", gap: 6, fontWeight: 500 }}>
          ← back
        </button>

        <div className="card" style={{ padding: "36px 32px" }}>
          <div style={{ marginBottom: 28 }}>
            <h2 style={{ fontFamily: "'Playfair Display', serif", fontSize: 26, fontWeight: 700, marginBottom: 6 }}>
              {step === "verify" ? "check your inbox" : isSig ? "join gossip-anonymous" : "welcome back"}
            </h2>
            <p style={{ color: C.textMuted, fontSize: 13, lineHeight: 1.6 }}>
              {step === "verify"
                ? `we sent a 6-digit code to ${email}`
                : isSig
                ? "your identity stays hidden. you'll always appear as anonymous_user — spill freely."
                : "sign in and spill the tea."}
            </p>
          </div>

          {step === "form" ? (
            <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
              <div>
                <label style={{ fontSize: 11, fontWeight: 700, color: C.textMuted, letterSpacing: "0.08em", textTransform: "uppercase", display: "block", marginBottom: 6 }}>email address</label>
                <input type="email" placeholder="you@somewhere.com" value={email} onChange={e => setEmail(e.target.value)} onKeyDown={e => e.key === "Enter" && submit()} />
              </div>
              <div>
                <label style={{ fontSize: 11, fontWeight: 700, color: C.textMuted, letterSpacing: "0.08em", textTransform: "uppercase", display: "block", marginBottom: 6 }}>password</label>
                <input type="password" placeholder="••••••••" value={pw} onChange={e => setPw(e.target.value)} onKeyDown={e => e.key === "Enter" && submit()} />
              </div>

              {isSig && (
                <div style={{ background: C.accentLight, border: `1px solid ${C.accentMid}`, borderRadius: 10, padding: "12px 16px", display: "flex", gap: 12, alignItems: "flex-start" }}>
                  <span style={{ fontSize: 16 }}>👤</span>
                  <div>
                    <p style={{ fontSize: 12, fontWeight: 600, color: C.text, marginBottom: 2 }}>you'll appear as <span style={{ color: C.accent }}>anonymous_user</span></p>
                    <p style={{ fontSize: 11, color: C.textMuted }}>your email is only for verification. nobody can see it.</p>
                  </div>
                </div>
              )}

              {err && <p style={{ color: C.red, fontSize: 12, fontWeight: 500 }}>{err}</p>}

              <button className="btn-primary" onClick={submit} disabled={loading} style={{ marginTop: 4, display: "flex", alignItems: "center", justifyContent: "center", gap: 8 }}>
                {loading ? <><Loader /> processing...</> : isSig ? "create account →" : "sign in →"}
              </button>

              <p style={{ textAlign: "center", fontSize: 12, color: C.textMuted }}>
                {isSig ? "already have an account? " : "new here? "}
                <button onClick={() => onNav(isSig ? "login" : "signup")} style={{ background: "none", color: C.accent, fontSize: 12, fontWeight: 600 }}>
                  {isSig ? "sign in" : "join gossip-anonymous"}
                </button>
              </p>
            </div>
          ) : (
            <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
              <p style={{ fontSize: 12, color: C.textMuted, background: C.bg, padding: "10px 14px", borderRadius: 8 }}>
                demo code: <strong style={{ color: C.accent, fontFamily: "monospace", fontSize: 14 }}>{vCode}</strong>
              </p>
              <input type="text" maxLength={6} placeholder="000000" value={code} onChange={e => setCode(e.target.value.replace(/\D/g, ""))} style={{ fontSize: 22, letterSpacing: "0.3em", textAlign: "center", fontFamily: "monospace" }} onKeyDown={e => e.key === "Enter" && verify()} />
              {err && <p style={{ color: C.red, fontSize: 12, fontWeight: 500 }}>{err}</p>}
              <button className="btn-primary" onClick={verify} style={{ display: "flex", alignItems: "center", justifyContent: "center", gap: 8 }}>
                verify & enter →
              </button>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

