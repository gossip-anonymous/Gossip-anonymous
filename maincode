  const totalComments = posts.reduce((n, p) => n + p.comments.reduce((m, c) => m + 1 + c.replies.length, 0), 0);
  const uniqueUsers = new Set(posts.map(p => p.email)).size;
  const topPost = [...posts].sort((a, b) => b.likes - a.likes)[0];
  const userActivity = {};
  posts.forEach(p => { userActivity[p.email] = (userActivity[p.email] || 0) + 1; });
  const topUser = Object.entries(userActivity).sort((a, b) => b[1] - a[1])[0];

  const grantAdmin = () => {
    if (!newAdmin || !/\S+@\S+\.\S+/.test(newAdmin)) { setAdminErr("enter a valid email."); return; }
    if (admins.has(newAdmin)) { setAdminErr("already an admin."); return; }
    setAdmins(prev => new Set([...prev, newAdmin]));
    setAdminErr(""); setAdminOk(`${newAdmin} is now an admin.`);
    setNewAdmin("");
    setTimeout(() => setAdminOk(""), 3000);
  };

  const revokeAdmin = (email) => {
    if (email === ADMIN_EMAIL) return;
    setAdmins(prev => { const n = new Set(prev); n.delete(email); return n; });
