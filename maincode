        {tab === "feed" && <FeedTab posts={posts} setPosts={setPosts} userEmail={userEmail} isAdmin={isAdmin} />}
        {tab === "profile" && <ProfileTab posts={posts} userEmail={userEmail} />}
        {tab === "admin" && isAdmin && <AdminTab posts={posts} setPosts={setPosts} admins={admins} setAdmins={setAdmins} userEmail={userEmail} />}
      </main>
    </div>
  );
}

// ─── Feed Tab ─────────────────────────────────────────────────────────────────
function FeedTab({ posts, setPosts, userEmail, isAdmin }) {
  const [draft, setDraft] = useState("");
  const [posting, setPosting] = useState(false);
  const [liked, setLiked] = useState(new Set());
  const [sortBy, setSortBy] = useState("recent");
  const [expandedComments, setExpandedComments] = useState(new Set());

  const handlePost = () => {
    if (!draft.trim() || draft.length > 280) return;
    setPosting(true);
    setTimeout(() => {
      setPosts(prev => [{
        id: Date.now(), email: userEmail, content: draft.trim(),
        likes: 0, time: "just now", tags: [], comments: []
      }, ...prev]);
      setDraft("");
      setPosting(false);
    }, 700);
  };

  const handleLike = (id) => {
    setLiked(prev => {
      const next = new Set(prev);
      if (next.has(id)) { next.delete(id); setPosts(p => p.map(x => x.id === id ? { ...x, likes: x.likes - 1 } : x)); }
      else { next.add(id); setPosts(p => p.map(x => x.id === id ? { ...x, likes: x.likes + 1 } : x)); }
      return next;
    });
  };

  const toggleComments = (id) => setExpandedComments(prev => {
    const next = new Set(prev);
    next.has(id) ? next.delete(id) : next.add(id);
    return next;
  });

  const addComment = (postId, content) => {
    setPosts(prev => prev.map(p => p.id === postId ? {
      ...p, comments: [...p.comments, { id: Date.now(), email: userEmail, content, likes: 0, time: "just now", replies: [] }]
    } : p));
  };

  const addReply = (postId, commentId, content) => {
    setPosts(prev => prev.map(p => p.id === postId ? {
      ...p, comments: p.comments.map(c => c.id === commentId ? {
        ...c, replies: [...c.replies, { id: Date.now(), email: userEmail, content, likes: 0, time: "just now" }]
      } : c)
    } : p));
  };

  const sorted = sortBy === "top" ? [...posts].sort((a, b) => b.likes - a.likes) : posts;

  return (
    <div style={{ maxWidth: 680, margin: "0 auto", padding: "32px 24px" }}>
      {/* Compose */}
      <div className="card fade-up" style={{ padding: 20, marginBottom: 28 }}>
        <div style={{ display: "flex", gap: 12, marginBottom: 12, alignItems: "center" }}>
          <div className="avatar">👤</div>
          <span style={{ fontSize: 13, color: C.textMuted }}>posting as <strong style={{ color: C.accent }}>anonymous_user</strong></span>
        </div>
        <textarea rows={3} placeholder="spill the tea ☕ — no one knows it's you." value={draft} onChange={e => setDraft(e.target.value)} style={{ marginBottom: 12 }} />
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
          <span style={{ fontSize: 11, color: draft.length > 280 ? C.red : C.textDim, fontWeight: 500 }}>{draft.length}/280</span>
          <button className="btn-primary" onClick={handlePost} disabled={posting || !draft.trim() || draft.length > 280} style={{ display: "flex", alignItems: "center", gap: 7, padding: "9px 20px" }}>
            {posting ? <><Loader /> posting...</> : "Post"}
          </button>
        </div>
      </div>

      {/* Tabs */}
      <div style={{ display: "flex", gap: 2, marginBottom: 20, background: C.surface, border: `1.5px solid ${C.border}`, borderRadius: 10, padding: 4 }}>
        {["recent", "top"].map(s => (
          <button key={s} onClick={() => setSortBy(s)} style={{
            flex: 1, padding: "8px 0", borderRadius: 7, fontSize: 13, fontWeight: 600,
            background: sortBy === s ? C.accent : "transparent",
            color: sortBy === s ? "#fff" : C.textMuted,
            border: "none", transition: "all 0.15s"
          }}>{s === "recent" ? "Recent" : "Top"}</button>
        ))}
      </div>

      {/* Posts */}
      <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
        {sorted.map((post, i) => (
          <PostCard key={post.id} post={post} liked={liked} onLike={handleLike}
            showComments={expandedComments.has(post.id)} onToggleComments={toggleComments}
            onAddComment={addComment} onAddReply={addReply} userEmail={userEmail}
            animDelay={i * 0.04} isAdmin={isAdmin} />
        ))}
      </div>

      <p style={{ textAlign: "center", color: C.textDim, fontSize: 12, marginTop: 40, fontWeight: 500 }}>
        — you've caught up on all the tea —
      </p>
    </div>
  );
}

// ─── Post Card ────────────────────────────────────────────────────────────────
function PostCard({ post, liked, onLike, showComments, onToggleComments, onAddComment, onAddReply, userEmail, animDelay, isAdmin }) {
  const [commentDraft, setCommentDraft] = useState("");
