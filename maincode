  const [likedComments, setLikedComments] = useState(new Set());

  const submitComment = () => {
    if (!commentDraft.trim()) return;
    setSubmitting(true);
    setTimeout(() => { onAddComment(post.id, commentDraft.trim()); setCommentDraft(""); setSubmitting(false); }, 500);
  };

  const totalComments = post.comments.reduce((n, c) => n + 1 + c.replies.length, 0);

  return (
    <div className="card fade-up" style={{ animationDelay: `${animDelay}s`, overflow: "hidden" }}>
      <div style={{ padding: "20px 22px" }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 14 }}>
          <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
            <div className="avatar">👤</div>
            <div>
              <span style={{ fontSize: 13, fontWeight: 600, color: C.accent, display: "block" }}>anonymous_user</span>
              <span style={{ fontSize: 11, color: C.textDim }}>{post.time}</span>
            </div>
          </div>
          {post.tags?.length > 0 && <span className="tag">#{post.tags[0]}</span>}
        </div>

        <p style={{ fontSize: 15, lineHeight: 1.68, color: C.text, marginBottom: 16 }}>{post.content}</p>

        {isAdmin && (
          <div style={{ background: "#fffbeb", border: `1px solid ${C.adminBorder}`, borderRadius: 8, padding: "8px 12px", marginBottom: 14, display: "flex", alignItems: "center", gap: 8 }}>
            <Icon name="mail" size={13} color={C.adminAccent} />
            <span style={{ fontSize: 12, color: C.adminAccent, fontWeight: 600 }}>{post.email}</span>
          </div>
        )}

        <div style={{ display: "flex", gap: 4, alignItems: "center" }}>
          <button onClick={() => onLike(post.id)} style={{
            background: liked.has(post.id) ? "#fff1f1" : "transparent",
            color: liked.has(post.id) ? C.red : C.textMuted,
            display: "flex", alignItems: "center", gap: 5, fontSize: 13, fontWeight: 600,
            padding: "6px 10px", borderRadius: 7, transition: "all 0.15s",
            border: `1px solid ${liked.has(post.id) ? "#fecaca" : "transparent"}`,
          }}>
            <Icon name={liked.has(post.id) ? "heartFill" : "heart"} size={14} color={liked.has(post.id) ? C.red : C.textMuted} />
            {post.likes}
          </button>

          <button onClick={() => onToggleComments(post.id)} style={{
            background: showComments ? C.accentLight : "transparent",
            color: showComments ? C.accent : C.textMuted,
            display: "flex", alignItems: "center", gap: 5, fontSize: 13, fontWeight: 600,
            padding: "6px 10px", borderRadius: 7, transition: "all 0.15s",
            border: `1px solid ${showComments ? C.accentMid : "transparent"}`,
          }}>
            <Icon name="comment" size={14} color={showComments ? C.accent : C.textMuted} />
            {totalComments} {totalComments === 1 ? "comment" : "comments"}
          </button>
        </div>
      </div>

      {showComments && (
        <div style={{ borderTop: `1px solid ${C.border}`, background: C.bg }}>
          {post.comments.length > 0 && (
            <div style={{ padding: "16px 22px", display: "flex", flexDirection: "column", gap: 12 }}>
              {post.comments.map(comment => (
                <CommentBlock key={comment.id} comment={comment} postId={post.id} onAddReply={onAddReply}
                  likedComments={likedComments} setLikedComments={setLikedComments} isAdmin={isAdmin} />
              ))}
            </div>
          )}

          <div style={{ padding: "12px 22px 16px", borderTop: post.comments.length > 0 ? `1px solid ${C.border}` : "none", display: "flex", gap: 10, alignItems: "flex-start" }}>
            <div className="avatar" style={{ width: 28, height: 28, fontSize: 12, marginTop: 2 }}>👤</div>
            <div style={{ flex: 1 }}>
              <textarea rows={2} placeholder="write a comment..." value={commentDraft} onChange={e => setCommentDraft(e.target.value)} style={{ fontSize: 13, marginBottom: 8 }} />
              <div style={{ display: "flex", justifyContent: "flex-end" }}>
                <button className="btn-primary" onClick={submitComment} disabled={submitting || !commentDraft.trim()} style={{ padding: "7px 16px", fontSize: 12, display: "flex", gap: 6, alignItems: "center" }}>
                  {submitting ? <><Loader /> posting...</> : "Post"}
                </button>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

// ─── Comment Block ────────────────────────────────────────────────────────────
function CommentBlock({ comment, postId, onAddReply, likedComments, setLikedComments, isAdmin }) {
  const [showReply, setShowReply] = useState(false);
  const [replyDraft, setReplyDraft] = useState("");
  const [submitting, setSubmitting] = useState(false);

  const submitReply = () => {
    if (!replyDraft.trim()) return;
    setSubmitting(true);
    setTimeout(() => { onAddReply(postId, comment.id, replyDraft.trim()); setReplyDraft(""); setSubmitting(false); setShowReply(false); }, 500);
  };

  const likeComment = (id) => {
    setLikedComments(prev => {
      const next = new Set(prev);
      next.has(id) ? next.delete(id) : next.add(id);
      return next;
    });
  };

  return (
    <div className="slide-in">
      <div style={{ display: "flex", gap: 10 }}>
        <div className="avatar" style={{ width: 26, height: 26, fontSize: 11 }}>👤</div>
        <div style={{ flex: 1 }}>
          <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 4 }}>
            <span style={{ fontSize: 12, fontWeight: 700, color: C.accent }}>anonymous_user</span>
            <span style={{ fontSize: 11, color: C.textDim }}>{comment.time}</span>
            {isAdmin && (
              <span style={{ fontSize: 11, color: C.adminAccent, background: "#fffbeb", padding: "1px 7px", borderRadius: 4, border: `1px solid ${C.adminBorder}`, display: "flex", alignItems: "center", gap: 4 }}>
                <Icon name="mail" size={10} color={C.adminAccent} /> {comment.email}
              </span>
            )}
          </div>
          <p style={{ fontSize: 13, lineHeight: 1.55, color: C.text, marginBottom: 6 }}>{comment.content}</p>
          <div style={{ display: "flex", gap: 8 }}>
            <button onClick={() => likeComment(comment.id)} style={{ background: "none", color: likedComments.has(comment.id) ? C.red : C.textMuted, fontSize: 12, fontWeight: 600, display: "flex", alignItems: "center", gap: 4 }}>
              <Icon name={likedComments.has(comment.id) ? "heartFill" : "heart"} size={12} color={likedComments.has(comment.id) ? C.red : C.textMuted} />
              {comment.likes + (likedComments.has(comment.id) ? 1 : 0)}
            </button>
            <button className="btn-text" onClick={() => setShowReply(r => !r)} style={{ fontSize: 12, color: showReply ? C.accent : C.textMuted }}>
              reply
            </button>
          </div>

          {showReply && (
            <div style={{ marginTop: 10, display: "flex", gap: 8, alignItems: "flex-start" }}>
              <textarea rows={2} placeholder="write a reply..." value={replyDraft} onChange={e => setReplyDraft(e.target.value)} style={{ fontSize: 13 }} />
              <button className="btn-primary" onClick={submitReply} disabled={submitting || !replyDraft.trim()} style={{ padding: "8px 14px", fontSize: 12, flexShrink: 0, display: "flex", gap: 6 }}>
                {submitting ? <Loader /> : "Post"}
              </button>
            </div>
          )}
        </div>
      </div>

      {comment.replies.length > 0 && (
        <div className="reply-indent" style={{ marginTop: 10 }}>
          {comment.replies.map(reply => (
            <div key={reply.id} style={{ display: "flex", gap: 10, marginBottom: 10 }}>
              <div className="avatar" style={{ width: 22, height: 22, fontSize: 10 }}>👤</div>
              <div>
                <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 3 }}>
                  <span style={{ fontSize: 12, fontWeight: 700, color: C.accent }}>anonymous_user</span>
                  <span style={{ fontSize: 11, color: C.textDim }}>{reply.time}</span>
                  {isAdmin && (
                    <span style={{ fontSize: 11, color: C.adminAccent, background: "#fffbeb", padding: "1px 7px", borderRadius: 4, border: `1px solid ${C.adminBorder}`, display: "flex", alignItems: "center", gap: 4 }}>
                      <Icon name="mail" size={10} color={C.adminAccent} /> {reply.email}
                    </span>
                  )}
                </div>
                <p style={{ fontSize: 13, lineHeight: 1.55, color: C.text }}>{reply.content}</p>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

